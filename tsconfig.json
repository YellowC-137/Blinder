{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,
    "allowJs": false,
    "checkJs": false
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "bin/**/*.ts",
    "bin/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "demo",
    "blinder_reports",
    "platform-test",
    "test_verification"
  ]
}
