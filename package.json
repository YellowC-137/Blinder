{
  "name": "blinder",
  "version": "1.0.0",
  "description": "Blinder - AI-Agent Security & Secret Protection with Plugin Architecture",
  "main": "index.js",
  "type": "module",
  "bin": {
    "blinder": "./bin/blinder.js"
  },
  "scripts": {
    "test": "node test/pattern_test.js && node test/platform_unit_test.js && node test/key_classifier_test.js && node test/parser_test.js",
    "test:integration": "node test/platform_integration_test.js && node test/objc_migration_test.js",
    "test:regression:ios": "bash test/regression/ios/run.sh",
    "test:regression:android": "bash test/regression/android/run.sh",
    "test:regression:flutter": "bash test/regression/flutter/run.sh",
    "test:regression:node": "bash test/regression/node/run.sh",
    "test:regression": "npm run test:regression:ios && npm run test:regression:android && npm run test:regression:flutter && npm run test:regression:node",
    "test:all": "npm test && npm run test:integration",
    "add-platform": "node bin/blinder.js add_platform"
  },
  "keywords": [
    "security",
    "secret-scanning",
    "ai-agent",
    "ios",
    "android",
    "flutter",
    "plugin-architecture",
    "env-protection"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "diff": "^9.0.0",
    "fast-glob": "^3.3.3",
    "inquirer": "^13.4.1",
    "ora": "^9.3.0",
    "plist": "^3.1.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "0.22.6",
    "xml2js": "^0.6.2"
  }
}
